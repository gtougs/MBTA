    {
      "id": "701141",
      "title": "",
      "description": "A shuttle bus will be available to transport customers between Arlington and Copley. To exit, exit the train at Copley and find station personnel or use a station call box to request the shuttle bus to Arlington. To board, find station personnel or use a station call box at Arlington to request the shuttle bus to Copley.",
      "severity": 3,
      "route_id": "unknown"
    },
